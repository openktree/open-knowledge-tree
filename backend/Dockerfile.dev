FROM golang:1.25-alpine
ENV GOTOOLCHAIN=auto
# Enable the community repo so we can install mupdf-dev
# (headers + pkg-config file) and mupdf-libs (runtime
# shared library). go-fitz's `extlib pkgconfig` build
# path shells out to `pkg-config mupdf` to discover the
# system MuPDF; without community, no mupdf.pc exists
# and the linker falls back to go-fitz's vendored
# glibc-built static archives — which fail on musl with
# undefined references to __*_chk fortified symbols.
RUN sed -i 's/^#\(.*community\)/\1/' /etc/apk/repositories
# build-base:    gcc + musl-dev, needed by CGo.
# libffi-dev:    headers for jupiterrider/ffi.
# libffi:        runtime shared library (libffi.so.8)
#                that jupiterrider/ffi dlopen()s in init().
# mupdf-dev:     headers + pkg-config file consumed by
#                go-fitz's extlib pkgconfig build path.
# mupdf-libs:    runtime shared library (libmupdf.so) and
#                its transitive deps (libjpeg, freetype,
#                harfbuzz, jbig2dec, gumbo, mujs, openjpeg).
# pkgconf:       pkg-config tool used by CGo to resolve
#                the `pkg-config: mupdf` directive.
RUN apk --no-cache add build-base libffi-dev libffi mupdf-dev mupdf-libs pkgconf ca-certificates
RUN go install github.com/air-verse/air@latest
ENV GOFLAGS=-tags=nocgo
# FZ_VERSION must match the installed mupdf-libs version so
# go-fitz's purego path can negotiate the context version
# with libmupdf.so. Without it, go-fitz defaults to "1.24.9"
# (its build version), context creation fails, and every
# PDF silently ends up with parse_status='unsupported'.
# Alpine 3.24's community repo ships mupdf-libs 1.27.2; bump
# the env to match or go-fitz's fz_new_context_imp rejects
# the header/library pair and every PDF parse is swallowed.
ENV FZ_VERSION=1.27.2
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ENTRYPOINT ["air"]
