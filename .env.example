# Open Knowledge Tree — environment configuration.
#
# 1. Copy this file to `.env` (same directory):
#      cp .env.example .env
# 2. Fill in the required keys below.
# 3. Run:  docker compose up
# 4. Open: http://localhost:3000
#
# Only the REQUIRED section needs values. Everything else has working
# defaults baked into the pre-built images and the compose file.

# === REQUIRED: chat model ===
# The decomposition + synthesis pipeline calls a chat model. Pick ONE
# provider and paste your API key:
OPENROUTER_API_KEY=
# OLLAMA_API_KEY=

# === REQUIRED: web search ===
# Serper (https://serper.dev) is the web-search provider that finds
# candidate sources. Get a key at https://serper.dev — free tier
# available.
SERPER_API_KEY=

# === Optional: improves DOI / academic resolution ===
# OpenAlex (https://openalex.org) is the academic-works search
# provider. An email gets you into the "polite pool" with higher
# rate limits. Leave empty to use it anonymously.
OPENALEX_EMAIL=
# Unpaywall (https://unpaywall.org) resolves open-access PDFs for
# DOI-tagged sources. An email is the de-facto API key. Leave empty
# to skip the open-access tier and resolve DOIs via plain HTTP fetch.
UNPAYWALL_EMAIL=

# === Optional: fetch / scraping tuning ===
# TLS-impersonation profile for the fetch tier. Set to a tls-client
# profile id (e.g. "chrome_124") to enable the TLS-fingerprint WAF
# bypass; empty disables it. Defaults to chrome_124.
# OKT_FETCH_IMPERSONATE=chrome_124

# FlareSolverr / Byparr is the headless-browser tier for JavaScript
# challenges (Cloudflare, Datadome, PerimeterX). The compose file
# boots three instances; this caps in-flight calls across the pool
# (one per Chromium). Lower to 1 for challenge-heavy hosts; raise
# to 6 for lighter pages. Defaults to 3.
# FLARESOLVERR_MAX_CONCURRENCY=3

# Override the full FlareSolverr endpoints list (comma-separated).
# Defaults to the three containers in the compose file.
# FLARESOLVERR_ENDPOINTS=http://flaresolverr:8191,http://flaresolverr2:8191,http://flaresolverr3:8191

# === Optional: pin a release tag ===
# The compose file pulls ghcr.io/openktree/api:${OKT_TAG:-latest} and
# the frontend image likewise. Defaults to `latest` (tracks the most
# recent release). Pin a specific version for reproducibility:
# OKT_TAG=v0.1.0

# === Internal defaults (do NOT put these in .env) ===
# The following are baked into docker-compose.yml's environment: block
# with safe dev defaults. Override them there only if you know what
# you're doing:
#   DATABASE_PASSWORD: okt_dev
#   AUTH_JWTSECRET:    change-me-in-production